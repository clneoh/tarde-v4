{
  "version": "1.0.0",
  "description": "Shared Service \u00c3\u0083\u00c2\u0083\u00c3\u0082\u00c2\u00a2\u00c3\u0083\u00c2\u0082\u00c3\u0082\u00c2\u0080\u00c3\u0083\u00c2\u0082\u00c3\u0082\u00c2\u0094 single source of truth for V4 and PAM. Regime, matrix, news, correlation, asset list.",
  "schedule": "every 15m, offset -2 min before V4 engine",
  "assets": {
    "TEST123": {
      "exchange": "TEST",
      "type": "stock",
      "session": "US",
      "bias_tf": [],
      "exec_tf": "H1",
      "enabled_v4": true,
      "enabled_pam": false
    }
  },
  "bias_model": {
    "rule": "majority_vote",
    "description": "Each bias TF votes LONG/SHORT based on price vs 20EMA. Majority wins. Tie \u00c3\u0083\u00c2\u0083\u00c3\u0082\u00c2\u00a2\u00c3\u0083\u00c2\u0082\u00c3\u0082\u00c2\u0086\u00c3\u0083\u00c2\u0082\u00c3\u0082\u00c2\u0092 neutral.",
    "ema_period": 20,
    "tie_result": "neutral",
    "fetch_policy": "only_fetch_required",
    "fetch_note": "Engines read bias_tf + exec_tf per asset. Do NOT fetch data for TFs not listed for that asset.",
    "user_note": "Add/remove TFs per asset in 'assets' section"
  },
  "modules": {
    "regime": {
      "enabled": true,
      "indicators": [
        "DXY",
        "VIX",
        "SPX",
        "US10Y",
        "BTC"
      ],
      "horizon_matrix": {
        "M1": {
          "risk-on": "free",
          "neutral": "free",
          "risk-off": "free"
        },
        "W1": {
          "risk-on": "LONG",
          "neutral": "free",
          "risk-off": "SHORT"
        },
        "D1": {
          "risk-on": "LONG",
          "neutral": "free",
          "risk-off": "SHORT"
        },
        "D2": {
          "risk-on": "LONG",
          "neutral": "free",
          "risk-off": "SHORT"
        },
        "H4": {
          "risk-on": "LONG",
          "neutral": "free",
          "risk-off": "SHORT"
        },
        "H1": {
          "risk-on": "free",
          "neutral": "free",
          "risk-off": "free"
        },
        "m15": {
          "risk-on": "free",
          "neutral": "free",
          "risk-off": "free"
        }
      }
    },
    "correlation": {
      "enabled": true,
      "checks": {
        "xau_vs_dxy": {
          "lookback_days": 5
        },
        "stocks_vs_spx": {
          "lookback_days": 5
