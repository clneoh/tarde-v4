{
  "version": "4.1.0",
  "scoring": {
    "method": "linear_scaled",
    "max_per_criteria": 10,
    "threshold_pct": 60,
    "note": "Each criteria 0-10 scaled by intensity. Pass if total ≥ 60% of max possible."
  },
  "assets": {
    "XAUUSD": {
      "exchange": "OANDA", "type": "commodity",
      "session": "24h",
      "timeframes": { "bias": "1h", "entry": "15m" }
    },
    "AAPL": {
      "exchange": "NASDAQ", "type": "stock",
      "session": "US equity (14:30-21:00 UTC)",
      "timeframes": { "bias": "1d", "entry": "1h" }
    },
    "META": {
      "exchange": "NASDAQ", "type": "stock",
      "session": "US equity (14:30-21:00 UTC)",
      "timeframes": { "bias": "1d", "entry": "1h" }
    },
    "GOOGL": {
      "exchange": "NASDAQ", "type": "stock",
      "session": "US equity (14:30-21:00 UTC)",
      "timeframes": { "bias": "1d", "entry": "1h" }
    },
    "MSFT": {
      "exchange": "NASDAQ", "type": "stock",
      "session": "US equity (14:30-21:00 UTC)",
      "timeframes": { "bias": "1d", "entry": "1h" }
    }
  },
  "regime": {
    "indicators": ["DXY", "VIX", "SPX", "US10Y", "BTC"],
    "horizon_matrix": {
      "W1":  { "risk-on": "LONG",  "neutral": "free", "risk-off": "SHORT" },
      "D1":  { "risk-on": "LONG",  "neutral": "free", "risk-off": "SHORT" },
      "H4":  { "risk-on": "LONG",  "neutral": "free", "risk-off": "SHORT" },
      "H1":  { "risk-on": "free",  "neutral": "free", "risk-off": "free"  },
      "15m": { "risk-on": "free",  "neutral": "free", "risk-off": "free"  }
    },
    "horizon_rules": {
      "short": "free",
      "long": "risk-on → LONG bias | risk-off → SHORT bias | neutral → free"
    },
    "gold_override": "gold direction NOT gated by regime"
  },
  "correlation": {
    "checks": {
      "xau_vs_dxy":    { "enabled": true, "lookback_days": 5,  "action": "warn" },
      "stocks_vs_spx": { "enabled": true, "lookback_days": 5,  "action": "warn" },
      "cross_stock_overlap": { "enabled": true, "action": "warn" },
      "gold_vs_stocks": { "enabled": true, "lookback_days": 20, "action": "warn" }
    }
  },
  "setups": {
    "XAUUSD": {
      "scoring_threshold_pct": 55,
      "rsi_gate": { "long_min": 35, "short_max": 65 },
      "signals": [
        {
          "name": "structure_break", "type": "breakout", "direction": "both",
          "criteria": [
            { "rule": "close beyond prior swing", "max": 10, "scaling": "swing_break" },
            { "rule": "volume", "max": 10, "scaling": "volume" },
            { "rule": "ATR expansion", "max": 10, "scaling": "atr_expand" },
            { "rule": "touches at level", "max": 10, "scaling": "touches" }
          ]
        },
        {
          "name": "ema_bounce", "type": "mean_reversion", "direction": "both",
          "criteria": [
            { "rule": "price proximity to 50EMA", "max": 10, "scaling": "ema_proximity" },
            { "rule": "engulfing candle", "max": 10, "scaling": "engulfing" },
            { "rule": "RSI", "max": 10, "scaling": "rsi_range" }
          ]
        }
      ]
    },
    "AAPL": {
      "scoring_threshold_pct": 55,
      "signals": [
        {
          "name": "dip_to_ema", "type": "mean_reversion", "direction": "long",
          "criteria": [
            { "rule": "price proximity to 20EMA daily", "max": 10, "scaling": "ema_proximity" },
            { "rule": "RSI dip", "max": 10, "scaling": "rsi_range" },
            { "rule": "engulfing or hammer on 1h", "max": 10, "scaling": "engulfing" },
            { "rule": "volume at dip", "max": 10, "scaling": "volume" }
          ]
        },
        {
          "name": "momentum_break", "type": "momentum", "direction": "long",
          "criteria": [
            { "rule": "new 20-day high", "max": 10, "scaling": "new_high" },
            { "rule": "volume", "max": 10, "scaling": "volume" },
            { "rule": "RSI momentum", "max": 10, "scaling": "rsi_momentum" },
            { "rule": "ATR expanding", "max": 10, "scaling": "atr_expand" }
          ]
        },
        {
          "name": "earnings_drift", "type": "earnings", "direction": "both",
          "criteria": [
            { "rule": "earnings within 24h", "max": 0, "scaling": "gate" },
            { "rule": "post-earnings gap", "max": 10, "scaling": "gap_size" },
            { "rule": "gap direction confirmed", "max": 10, "scaling": "drift_confirm" },
            { "rule": "volume", "max": 10, "scaling": "volume" }
          ]
        }
      ]
    },
    "META": {
      "scoring_threshold_pct": 55,
