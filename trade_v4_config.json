  },
  "instrument": {
    "XAUUSD": { "primary": "OANDA Spot", "note": "No overnight swap, short natively" },
    "AAPL":   { "primary": "Cash Equity", "note": "Long=buy, Short=sell (margin+borrow)" },
    "META":   { "primary": "Cash Equity", "note": "Long=buy, Short=sell (margin+borrow)" },
    "GOOGL":  { "primary": "Cash Equity", "note": "Long=buy, Short=sell (margin+borrow)" },
    "MSFT":   { "primary": "Cash Equity", "note": "Long=buy, Short=sell (margin+borrow)" }
  },
  "entry": {
    "type": "limit",
    "rules": [
      "place limit order at identified level",
      "order valid for current session only",
      "no market orders"
    ],
    "session_filter": {
      "XAUUSD": "gold_session", "AAPL": "regular_only",
      "META": "regular_only", "GOOGL": "regular_only", "MSFT": "regular_only"
    },
    "regular_hours": { "timezone": "Asia/Singapore", "start": "21:30", "end": "04:00" },
    "pre_market_start": { "timezone": "Asia/Singapore", "start": "16:00" },
    "gold_hours": {
      "timezone": "Asia/Singapore",
      "sessions": [
        { "name": "Tokyo",  "start": "07:00", "end": "16:00" },
        { "name": "London", "start": "15:00", "end": "00:00" },
        { "name": "NY",     "start": "20:00", "end": "05:00" }
      ]
    },
    "structure_reference": { "pre_market_included": true }
  },
  "sizing": {
    "capital": 10000,
    "risk_per_trade_pct": 2.0,
    "risk_per_trade_note": "2% of allocation, not total capital",
    "max_leverage": 10,
    "atr_period": 14,
    "atr_multiplier_sl": 1.2,
    "stock_position_max_pct": 25,
    "gold_position_max_pct": 10,
    "max_correlated_exposure_pct": 40
  },
  "stops_and_targets": {
    "sl_method": "tighter_of",
    "sl_structural": { "type": "swing_high_low", "buffer_pct": 0.1, "timeframe": "entry_tf" },
    "sl_atr": { "method": "multiplier", "multiplier": 1.2, "period": 14, "timeframe": "entry_tf" },
    "sl_hard_caps": { "stock_max_pct": 5.0, "gold_rps_max_pct": 2.0 },
    "tp_rr_minimum": 1.5, "tp_rr_default": 2.0, "tp_structure_cap": 0.95,
    "breakeven_rule": "move SL to entry at +1R",
    "trailing_activation_r": 1.5
  },
  "journal": {
    "log_path": "/tmp/trade_v4_journal.json",
    "text_log": "/tmp/trade_v4_trades.txt",
    "auto_tag": ["asset", "setup_type", "regime", "direction", "horizon"],
    "weekly_review_fields": ["win_rate_by_setup", "win_rate_by_asset", "win_rate_by_regime", "avg_rr", "max_drawdown"]
  },
  "bonuses": {
    "calendar": { "enabled": true, "points": 10, "note": "Economic event aligns with direction" },
    "fedwatch": { "enabled": true, "points_weak": 10, "points_strong": 20, "note": "CME rate probabilities" },
    "fundamentals": { "enabled": true, "points": 10, "note": "Analyst targets/ratings/short%" }
  }
}